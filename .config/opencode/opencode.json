{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "oh-my-openagent",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "figma-mcp-go": {
      "command": ["npx", "-y", "@vkhanhqui/figma-mcp-go@latest"],
      "type": "local",
      "enabled": true
    }
  }
}
