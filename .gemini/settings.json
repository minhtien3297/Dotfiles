{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": true,
    "enableNotifications": true
  },
  "ui": {
    "inlineThinkingMode": "full",
    "showStatusInTitle": true,
    "showMemoryUsage": true,
    "showModelInfoInChat": true,
    "terminalBuffer": true,
    "loadingPhrases": "off",
    "footer": {
      "showLabels": true,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "memory-usage",
        "context-used",
        "code-changes",
        "token-count"
      ]
    }
  },
  "ide": {
    "enabled": false
  },
  "billing": {
    "overageStrategy": "never"
  },
  "model": {
    "name": ""
  },
  "experimental": {
    "modelSteering": true,
    "directWebFetch": true,
    "memoryManager": true
  },
  "mcpServers": {
    "agentation": {
      "command": "npx",
      "args": [
        "-y",
        "agentation-mcp",
        "server"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    }
  }
}